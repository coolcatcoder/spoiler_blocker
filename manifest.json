{
    "manifest_version": 2,
    "name": "Spoiler Blocker",
    "version": "1.0",
    "description": "Block spoilers.",
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "main.js"
            ]
        }
    ],
    "options_ui": {
        "page": "options.html"
    },
    "permissions": [
        "storage"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "@spoiler.blocker"
        }
    }
}